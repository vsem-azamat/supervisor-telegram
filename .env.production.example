# Production environment template for ~/deploy/supervisor-telegram/.env on the VPS.
# Do not commit real values. Keep development bots, databases, and userbot sessions separate.

# Written by GitHub Actions on deploy. For initial bootstrap, set any already-published image SHA.
IMAGE_TAG=
WEBUI_PORT=5173

# Moderator bot
MODERATOR_BOT_TOKEN=

# Assistant bot
ASSISTANT_BOT_ENABLED=false
ASSISTANT_BOT_TOKEN=
ASSISTANT_BOT_MODEL=anthropic/claude-sonnet-4-6

# Admins
ADMIN_SUPER_ADMINS=
ADMIN_REPORT_CHAT_ID=

# PostgreSQL
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=
POSTGRES_WAIT_ATTEMPTS=60

# Application
APP_DEBUG=false
APP_ENVIRONMENT=production
APP_TIMEZONE=UTC

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# LLM providers
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
BRAVE_API_KEY=

# Moderation
MODERATION_ENABLED=true
MODERATION_MODEL=google/gemini-3.1-flash-lite-preview
MODERATION_ESCALATION_TIMEOUT_MINUTES=30
MODERATION_DEFAULT_TIMEOUT_ACTION=ignore
MODERATION_AD_DETECTOR_ENABLED=true
MODERATION_AD_DETECTOR_WHITELIST=
MODERATION_AD_DETECTOR_SNIPPET_CHARS=200

# Channel content agent
CHANNEL_ENABLED=false
CHANNEL_FETCH_INTERVAL_MINUTES=60
CHANNEL_SCREENING_MODEL=google/gemini-3.1-flash-lite-preview
CHANNEL_GENERATION_MODEL=google/gemini-3.1-flash-lite-preview
CHANNEL_VISION_MODEL=google/gemini-2.5-flash
CHANNEL_IMAGE_PHASH_LOOKBACK_POSTS=30
CHANNEL_IMAGE_PHASH_THRESHOLD=10
CHANNEL_SCREENING_THRESHOLD=5
CHANNEL_TEMPERATURE=0.3
CHANNEL_HTTP_TIMEOUT=30
CHANNEL_DISCOVERY_ENABLED=true
CHANNEL_DISCOVERY_MODEL=perplexity/sonar
CHANNEL_SOURCE_DISCOVERY_ENABLED=true
CHANNEL_SOURCE_DISCOVERY_INTERVAL_HOURS=24
CHANNEL_CRITIC_ENABLED=false
CHANNEL_CRITIC_MODEL=anthropic/claude-sonnet-4-6
CHANNEL_BRAVE_DISCOVERY_ENABLED=false
CHANNEL_EMBEDDING_MODEL=openai/text-embedding-3-small
CHANNEL_SEMANTIC_DEDUP_THRESHOLD=0.85
CHANNEL_DEDUP_LOOKBACK_DAYS=7
CHANNEL_DEDUP_QUERY_SNIPPET_CHARS=200
CHANNEL_BACKFILL_BATCH_SIZE=32

# Telethon userbot. TELETHON_PHONE is for first-time login only; remove it after the session is created.
TELETHON_ENABLED=false
TELETHON_API_ID=0
TELETHON_API_HASH=
TELETHON_SESSION_NAME=moderator_userbot
# TELETHON_PHONE=

# Web admin UI
WEBAPI_AUTH_MODE=telegram
WEBAPI_PUBLIC_URL=
WEBAPI_ALLOWED_ORIGINS=
WEBAPI_MAGIC_LINK_TTL_MINUTES=15
WEBAPI_SESSION_TTL_DAYS=30
WEBAPI_SESSION_COOKIE_SECURE=true
WEBAPI_SESSION_COOKIE_SAMESITE=lax
WEBAPI_SESSION_COOKIE_NAME=konnekt_admin_session

# Sponsored ads rate-card funnel
SPONSORED_ADS_ENABLED=false
SPONSORED_ADS_MODERATOR_CHAT_ID=0
SPONSORED_ADS_SALES_CONTACT=
