# Bot Configuration
BOT_TOKEN=your_bot_token_here
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=
BOT_USE_WEBHOOK=false

# Admin Configuration
ADMIN_SUPER_ADMINS=123456789,987654321
ADMIN_REPORT_CHAT_ID=

# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_password_here
# DB_HOST=db # [Optional]
# DB_PORT=5432 # [Optional]
DB_NAME=moderator_bot

# Application Configuration
DEBUG=false
ENVIRONMENT=development
TIMEZONE=UTC

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE_PATH=logs/bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Telethon (Telegram Client API) Configuration
TELETHON_ENABLED=false
TELETHON_API_ID=0
TELETHON_API_HASH=
TELETHON_SESSION_NAME=moderator_userbot
# TELETHON_PHONE=+1234567890  # Required for first-time auth only

# Assistant Bot Configuration
ASSISTANT_BOT_TOKEN=
ASSISTANT_BOT_ENABLED=false

# Agent Configuration (shared OpenRouter credentials)
AGENT_OPENROUTER_API_KEY=
AGENT_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AGENT_MODERATION_MODEL=google/gemini-3.1-flash-lite-preview
AGENT_ASSISTANT_MODEL=anthropic/claude-sonnet-4-6
AGENT_TEMPERATURE=0.3
AGENT_ENABLED=false
AGENT_ESCALATION_TIMEOUT_MINUTES=30
AGENT_DEFAULT_TIMEOUT_ACTION=ignore
AGENT_BRAVE_API_KEY=

# Channel Content Agent Configuration
CHANNEL_ENABLED=false
CHANNEL_FETCH_INTERVAL_MINUTES=60
CHANNEL_SCREENING_MODEL=google/gemini-3.1-flash-lite-preview
CHANNEL_GENERATION_MODEL=google/gemini-3.1-flash-lite-preview
CHANNEL_SCREENING_THRESHOLD=5
CHANNEL_TEMPERATURE=0.3
CHANNEL_HTTP_TIMEOUT=30
CHANNEL_DISCOVERY_ENABLED=true
CHANNEL_DISCOVERY_MODEL=perplexity/sonar
CHANNEL_SOURCE_DISCOVERY_ENABLED=true
CHANNEL_SOURCE_DISCOVERY_INTERVAL_HOURS=24
CHANNEL_EMBEDDING_MODEL=openai/text-embedding-3-small
CHANNEL_SEMANTIC_DEDUP_THRESHOLD=0.85
# CHANNEL_CHANNELS='[{"channel_id": "@your_channel", "review_chat_id": -100123, "language": "ru", "max_posts_per_day": 3}]'

# Adminer Configuration (for development)
ADMINER_PORT=8080
