+class IAgentDecisionRepository(ABC):
+    """Agent decision repository interface."""
+
+    @abstractmethod
+    async def log_decision(self, decision: AgentDecisionEntity) -> AgentDecisionEntity:
+        """Log a new agent decision and return it with assigned ID."""
+        pass
+
+    @abstractmethod
+    async def set_admin_override(self, decision_id: int, override_action: str) -> None:
+        """Record that an admin overrode the agent's decision."""
+        pass
+
+    @abstractmethod
+    async def get_user_history(self, user_id: int, limit: int = 10) -> list[AgentDecisionEntity]:
+        """Get recent decisions about a user."""
+        pass
+
+    @abstractmethod
+    async def get_chat_history(self, chat_id: int, limit: int = 20) -> list[AgentDecisionEntity]:
+        """Get recent decisions in a chat."""
+        pass
+
+    @abstractmethod
+    async def get_recent_corrections(self, limit: int = 10) -> list[AgentDecisionEntity]:
+        """Get recent decisions where admin overrode the agent."""
+        pass
+
+    @abstractmethod
+    async def get_user_risk_profile(self, user_id: int) -> dict[str, Any]:
+        """Build aggregate risk profile for a user.
+
+        Returns dict with keys: total_reports, distinct_reporters,
+        distinct_chats, actions_taken, overridden_count, last_action.
+        """
+        pass
+
+
+class IAgentEscalationRepository(ABC):
+    """Agent escalation repository interface."""
+
+    @abstractmethod
+    async def create(self, escalation: AgentEscalationEntity) -> AgentEscalationEntity:
+        """Create a new escalation and return it with assigned ID."""
+        pass
+
+    @abstractmethod
+    async def get_pending(self, escalation_id: int) -> AgentEscalationEntity | None:
+        """Get a pending escalation by ID."""
+        pass
+
+    @abstractmethod
+    async def resolve(
+        self, escalation_id: int, admin_id: int, action: str, resolved_at: Any
+    ) -> AgentEscalationEntity | None:
+        """Resolve an escalation with admin's chosen action."""
+        pass
+
+    @abstractmethod
+    async def update(self, escalation: AgentEscalationEntity) -> AgentEscalationEntity:
+        """Update an existing escalation (e.g. set admin_message_id)."""
+        pass
+
+    @abstractmethod
+    async def recover_stale(self, now: Any, default_action: str) -> int:
+        """Mark stale pending escalations as timed out. Returns count recovered."""
+        pass
+
+    @abstractmethod
+    async def mark_timeout(
+        self, escalation_id: int, default_action: str, resolved_at: Any
+    ) -> AgentEscalationEntity | None:
+        """Mark a specific escalation as timed out."""
+        pass
