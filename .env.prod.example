# ==============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env for production deployment
# Fill in all required values marked with [REQUIRED]
# Uncomment optional values only if needed

# ==============================================================================
# Bot Configuration [REQUIRED]
# ==============================================================================
BOT_TOKEN=your_bot_token_here

# Webhook Configuration (Optional - bot uses polling by default)
# Uncomment these if you want to use webhooks instead of polling
# BOT_WEBHOOK_URL=https://yourdomain.com/api/v1/telegram/webhook
# BOT_WEBHOOK_SECRET=your_random_secure_secret_here
# BOT_USE_WEBHOOK=false

# ==============================================================================
# Admin Configuration [REQUIRED]
# ==============================================================================
ADMIN_SUPER_ADMINS=123456789,987654321
# ADMIN_REPORT_CHAT_ID=  # Optional: specific chat for reports

# ==============================================================================
# Database Configuration [REQUIRED]
# ==============================================================================
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_NAME=moderator_bot

# Optional: Override database connection (defaults: db:5432)
# DB_HOST=db
# DB_PORT=5432

# ==============================================================================
# Application Configuration
# ==============================================================================
DEBUG=false
ENVIRONMENT=production
TIMEZONE=UTC

# ==============================================================================
# Logging Configuration
# ==============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE_PATH=logs/bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ==============================================================================
# Web App Configuration [REQUIRED]
# ==============================================================================
# Your domain with HTTPS (required for Telegram WebApp)
WEBAPP_URL=https://yourdomain.com

# API secret for webapp-backend communication
WEBAPP_API_SECRET=your_secure_api_secret_key_here

# ==============================================================================
# AI Agent Configuration (Optional)
# ==============================================================================
# OpenAI API key for GPT models (required if using OpenAI provider)
# OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API key for multiple AI models (required if using OpenRouter)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Custom base URLs for AI providers
# IMPORTANT: Comment out or remove if not using custom URLs
# Setting empty value will cause connection errors!
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ==============================================================================
# Docker Configuration (Optional)
# ==============================================================================
# Override nginx port if needed (default: 80)
# NGINX_PORT=80

# ==============================================================================
# DEVELOPMENT-ONLY VARIABLES - DO NOT USE IN PRODUCTION
# ==============================================================================
# These are only for development with docker-compose.override.yml
# Comment out or remove in production:

# WEBAPP_PORT=3000
# API_PORT=8000
# ADMINER_PORT=8080
# DB_PORT=5432
